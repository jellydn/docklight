# Required
JWT_SECRET=change-me-in-production

# Dokku SSH connection
# IMPORTANT: Use a container-reachable address, not the public VPS IP.
# The Docker bridge gateway (172.17.0.1) usually works.
DOCKLIGHT_DOKKU_SSH_TARGET=dokku@172.17.0.1
DOCKLIGHT_DOKKU_SSH_KEY_PATH=/app/.ssh/id_ed25519
# DOCKLIGHT_DOKKU_SSH_OPTS=

# Database
# DOCKLIGHT_DB_PATH=/app/data/docklight.db

# Logging
# LOG_LEVEL=info

# Rate limiting (optional, production defaults shown)
# DOCKLIGHT_RATE_LIMIT_WINDOW_MS=900000
# DOCKLIGHT_AUTH_MAX_REQUESTS=5
# DOCKLIGHT_AUTH_CHECK_MAX_REQUESTS=300
# DOCKLIGHT_COMMAND_WINDOW_MS=60000
# DOCKLIGHT_COMMAND_MAX_REQUESTS=30
# DOCKLIGHT_ADMIN_MAX_REQUESTS=30
